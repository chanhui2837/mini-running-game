let lastSaveTime = 0;

function saveUserData(force = false) {

    if (!loggedInUser || loggedInUser === "Player") return;
    if (!socket || !socket.connected) return;

    const now = Date.now();

    // 너무 자주 저장되는 것 방지 (강제 저장 제외)
    if (!force && now - lastSaveTime < 3000) return;

    lastSaveTime = now;

    let userData = {
        id: loggedInUser,
        custom: {
            color: curColor,
            hat: curHat,
            cloth: curCloth
        },
        highScore: curHighScore,
        hardHighScore: curHardHighScore,
        totalCoins: totalCoins,
        unlockedItems: unlockedItems
    };

    socket.emit("saveUserData", userData);
}